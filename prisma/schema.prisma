generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Contas: apenas MASTER (tudo), ADMIN (site e conteúdo) e CUSTOMER (reservas).
model User {
  id                          String              @id @default(uuid())
  name                        String
  email                       String              @unique
  phone                       String?
  cpf                         String?
  passwordHash                String
  role                        UserRole
  isActive                    Boolean             @default(true)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  mustChangePassword          Boolean             @default(false)
  isAdmin                     Boolean             @default(false)
  auditLogs                   AuditLog[]          @relation("UserAuditLogs")
  pendingSiteChangesRequested PendingSiteChange[]
  pendingSiteChangesReviewed  PendingSiteChange[] @relation("PendingSiteChangeReviewedBy")
  sentEmails                  SentEmail[]         @relation("SentEmailPerformedBy")
  verificationTokens          VerificationToken[]
  pendingTestimonialsReviewed PendingTestimonial[] @relation("PendingTestimonialReviewedBy")
  supportTickets              SupportTicket[]
  smsCampaignsCreated         SmsCampaign[]       @relation("SmsCampaignCreatedBy")
  smsCampaignsConfirmed       SmsCampaign[]       @relation("SmsCampaignConfirmedBy")
  smsCampaignsCanceled        SmsCampaign[]       @relation("SmsCampaignCanceledBy")
  smsTemplatesCreated         SmsTemplate[]       @relation("SmsTemplateCreatedBy")
  emailCampaignsCreated       EmailCampaign[]     @relation("EmailCampaignCreatedBy")
  emailCampaignsConfirmed     EmailCampaign[]     @relation("EmailCampaignConfirmedBy")
  emailCampaignsCanceled      EmailCampaign[]     @relation("EmailCampaignCanceledBy")
  emailTemplatesCreated       EmailTemplate[]     @relation("EmailTemplateCreatedBy")
  reservations                Reservation[]
  supportTicketMessages       SupportTicketMessage[] @relation("SupportTicketMessageAuthor")
}

model Package {
  id                    String        @id @default(uuid())
  name                  String
  slug                  String        @unique
  description           String?       @db.Text
  shortDescription      String?
  price                 Decimal       @db.Decimal(12, 2)
  childPrice            Decimal       @db.Decimal(12, 2) @default(0)
  breakfastKitAvailable Boolean       @default(false)
  breakfastKitPrice     Decimal       @db.Decimal(12, 2) @default(0)
  /** Informação exibida no ato da reserva sobre quando/como os kits serão entregues. */
  kitsDeliveryInfo      String?       @db.Text
  departureDate         DateTime      @db.Date
  departureTime         String
  boardingLocation      String
  capacity              Int
  status                PackageStatus @default(OPEN)
  coverImageUrl         String?
  galleryImages         String[]      @default([])
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  reservations          Reservation[]

  @@index([slug])
  @@index([status, isActive])
}

model Reservation {
  id                            String            @id @default(uuid())
  userId                        String
  packageId                     String
  customerNameSnapshot          String
  customerEmailSnapshot         String
  customerPhoneSnapshot         String
  quantity                      Int
  adultsCount                   Int               @default(1)
  childrenCount                 Int               @default(0)
  /** Nome completo por adulto (mesma ordem de `adultShirtSizes`). */
  adultNames                    String[]          @default([])
  /** Tamanho (PP/P/M/G/...) por adulto. */
  adultShirtSizes               String[]          @default([])
  /** Nome completo por criança (mesma ordem de `childrenShirtNumbers` / `childrenAges`). */
  childrenNames                 String[]          @default([])
  /** Idade por criança (regras atuais: 6 a 10). */
  childrenAges                  Int[]             @default([])
  /** Crianças: número/tamanho da camisa (ex.: 6, 8, 10, 12). */
  childrenShirtNumbers          Int[]             @default([])
  /** Café da manhã marcado por ingresso (adultos + crianças, nesta ordem: adultos primeiro). */
  breakfastSelections           Boolean[]         @default([])
  /** Kit café (pago) marcado por adulto (mesma ordem dos adultos). */
  breakfastKitSelections        Boolean[]         @default([])
  /** Compatibilidade/legado: true se algum kit foi marcado. */
  includesBreakfastKit          Boolean           @default(false)
  /** Preferência informada no ato da reserva (PIX, DINHEIRO, CARTAO, etc). */
  paymentPreferenceMethod       String?           @db.VarChar(30)
  /** Quando o método for cartão, número de parcelas desejado. */
  paymentPreferenceInstallments Int?
  unitPriceSnapshot             Decimal           @db.Decimal(12, 2)
  breakfastKitUnitPriceSnapshot Decimal           @db.Decimal(12, 2)
  totalPrice                    Decimal           @db.Decimal(12, 2)
  amountAdultSnapshot           Decimal           @db.Decimal(12, 2) @default(0)
  amountChildSnapshot           Decimal           @db.Decimal(12, 2) @default(0)
  totalDue                      Decimal           @db.Decimal(12, 2) @default(0)
  totalPaid                     Decimal           @db.Decimal(12, 2) @default(0)
  paymentStatus                 ReservationPaymentStatus @default(UNPAID)
  status                        ReservationStatus @default(PENDING)
  notes                         String?           @db.Text
  kitsDeliveryInfoSnapshot      String?
  reservedAt                    DateTime          @default(now())
  confirmedAt                   DateTime?
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime          @updatedAt
  user                          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  package                       Package           @relation(fields: [packageId], references: [id], onDelete: Restrict)
  payments                      ReservationPayment[]
  installments                  ReservationInstallment[]
  vouchers                      ReservationVoucher[]

  @@index([userId])
  @@index([packageId])
  @@index([packageId, status])
}

model ReservationVoucher {
  id            String   @id @default(uuid())
  reservationId String
  /** Snapshot para consultas/numeração por lote. */
  packageId     String
  /** Índice 0-based do adulto/criança dentro de cada grupo. */
  personIndex   Int
  personType    VoucherPersonType
  /** Código numérico sequencial (por lote) dentro de faixas por regra de negócio. */
  codeNumber    Int?
  /** Código exibido (ex.: 0001, 1001, 2001). */
  code          String   @unique
  name          String
  age           Int?
  shirtSize     String
  hasBreakfastKit Boolean @default(false)
  createdAt     DateTime @default(now())
  usedAt        DateTime?
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([packageId])
  @@index([code])
  @@unique([reservationId, personType, personIndex])
  @@unique([packageId, codeNumber])
}

enum VoucherPersonType {
  ADULT
  CHILD
}

enum ReservationPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELED
}

enum PackageStatus {
  DRAFT
  SOON
  OPEN
  SOLD_OUT
  CLOSED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
  TRANSFER
  OTHER
}

enum InstallmentStatus {
  SCHEDULED
  PAID
  CANCELED
}

model ReservationPayment {
  id            String        @id @default(uuid())
  reservationId String
  amount        Decimal       @db.Decimal(12, 2)
  paidAt        DateTime      @default(now())
  method        PaymentMethod
  note          String?       @db.Text
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([paidAt])
}

model ReservationInstallment {
  id            String             @id @default(uuid())
  reservationId String
  dueDate       DateTime           @db.Date
  amount        Decimal            @db.Decimal(12, 2)
  status        InstallmentStatus  @default(SCHEDULED)
  paidAt        DateTime?
  method        PaymentMethod?
  note          String?            @db.Text
  receiptUrl    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  reservation   Reservation        @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([dueDate, status])
}

model SentEmail {
  id                String   @id @default(uuid())
  to                String
  subject           String
  messageId         String?
  emailType         String
  entityType        String?
  entityId          String?
  sentAt            DateTime @default(now())
  performedByUserId String?
  performedByUser   User?    @relation("SentEmailPerformedBy", fields: [performedByUserId], references: [id])
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  type      VerificationTokenType
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VerificationTokenType {
  PASSWORD_RESET
  EMAIL_VERIFY
}

model AuditLog {
  id                String   @id @default(uuid())
  entityType        String
  entityId          String
  action            String
  diffJson          String
  performedByUserId String?
  createdAt         DateTime @default(now())
  performedByUser   User?    @relation("UserAuditLogs", fields: [performedByUserId], references: [id])
}

model SiteSettings {
  id                    String   @id @default(uuid())
  siteName              String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String?
  secondaryColor        String?
  /// Fundo do menu (barra superior); se vazio, usa o fundo do tema (--background).
  menuBackgroundColor   String?
  contactEmail          String?
  contactPhone          String?
  contactWhatsapp       String?
  businessHours         String?
  socialInstagram       String?
  socialFacebook        String?
  socialYoutube         String?
  socialLinkedin        String?
  seoTitleDefault       String?
  seoDescriptionDefault String?
  /// Open Graph / compartilhamento (WhatsApp, Facebook, etc.); se vazio, usa SEO padrão / logo.
  socialShareTitle       String?
  socialShareDescription String? @db.Text
  socialShareImageUrl    String?
  publicAppUrl          String?
  updatedAt             DateTime @updatedAt
  addresses             Json?
}

model SiteAboutPage {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteMenuItem {
  id         String         @id @default(uuid())
  label      String
  href       String
  order      Int            @default(0)
  parentId   String?
  isExternal Boolean        @default(false)
  isVisible  Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  parent     SiteMenuItem?  @relation("MenuItemsHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   SiteMenuItem[] @relation("MenuItemsHierarchy")
}

model SiteBanner {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteGalleryYear {
  id        String            @id @default(uuid())
  year      Int               @unique
  title     String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  photos    SiteGalleryPhoto[]

  @@index([year])
  @@index([isActive])
}

model SiteGalleryPhoto {
  id        String          @id @default(uuid())
  yearId    String
  imageUrl  String
  caption   String?
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  year      SiteGalleryYear @relation(fields: [yearId], references: [id], onDelete: Cascade)

  @@index([yearId, order])
}

model TabletBanner {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContatoPage {
  id             String   @id @default(uuid())
  title          String?
  subtitle       String?
  headerImageUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteProject {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  summary       String?
  content       String?
  coverImageUrl String?
  galleryImages String[] @default([])
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteTestimonial {
  id            String   @id @default(uuid())
  name          String
  roleOrContext String?
  quote         String
  photoUrl      String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PendingTestimonial {
  id               String    @id @default(uuid())
  name             String
  roleOrContext    String?
  quote            String
  photoUrl         String?
  status           String    @default("pending")
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  reviewedBy       User?     @relation("PendingTestimonialReviewedBy", fields: [reviewedByUserId], references: [id])
}

model SitePartner {
  id         String   @id @default(uuid())
  name       String
  logoUrl    String?
  websiteUrl String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactMessage {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?
  repliedAt DateTime?
}

model SupportTicket {
  id                String              @id @default(uuid())
  userId            String
  protocolNumber    String              @unique
  subject           String
  summary           String
  status            SupportTicketStatus @default(OPEN)
  attachmentUrls    String[]            @default([])
  attachmentNames   String[]            @default([])
  studentLastReadAt DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          SupportTicketMessage[]
}

model SupportTicketMessage {
  id             String        @id @default(uuid())
  ticketId       String
  authorUserId   String
  isFromSupport  Boolean       @default(false)
  content        String
  createdAt      DateTime      @default(now())
  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author         User          @relation("SupportTicketMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
}

enum SupportTicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

model SiteNewsCategory {
  id       String         @id @default(uuid())
  name     String
  slug     String         @unique
  order    Int            @default(0)
  isActive Boolean        @default(true)
  posts    SiteNewsPost[]
}

model SiteNewsPost {
  id            String            @id @default(uuid())
  title         String
  slug          String            @unique
  excerpt       String?
  content       String?
  coverImageUrl String?
  categoryId    String?
  publishedAt   DateTime?
  isPublished   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  imageUrls     String[]          @default([])
  category      SiteNewsCategory? @relation(fields: [categoryId], references: [id])
}

model SiteFaqItem {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteTransparencyCategory {
  id         String                     @id @default(uuid())
  name       String
  slug       String                     @unique
  order      Int                        @default(0)
  isActive   Boolean                    @default(true)
  documents  SiteTransparencyDocument[]
}

model SiteTransparencyDocument {
  id         String                   @id @default(uuid())
  categoryId String
  title      String
  description String?
  date       DateTime?                @db.Date
  fileUrl    String?
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  category   SiteTransparencyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model PendingSiteChange {
  id                String    @id @default(uuid())
  requestedByUserId String
  entityType        String
  action            String
  entityId          String?
  payload           Json
  status            String    @default("pending")
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  requestedBy       User      @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy        User?     @relation("PendingSiteChangeReviewedBy", fields: [reviewedByUserId], references: [id])
}

enum UserRole {
  MASTER
  ADMIN
  CUSTOMER
}

// --- SMS ---
model SmsCampaign {
  id                     String               @id @default(uuid())
  name                   String
  description            String?
  audienceType           SmsAudienceType
  audienceFilters        Json?
  templateId             String?
  messageContent         String?
  messageCharCount       Int?
  status                 SmsCampaignStatus    @default(DRAFT)
  totalFound             Int                  @default(0)
  totalValid             Int                  @default(0)
  totalMissingPhone      Int                  @default(0)
  totalInvalidPhone      Int                  @default(0)
  totalDuplicatesRemoved Int                  @default(0)
  totalSent              Int                  @default(0)
  totalDelivered         Int                  @default(0)
  totalFailed            Int                  @default(0)
  scheduledAt            DateTime?
  startedAt              DateTime?
  finishedAt             DateTime?
  createdById            String
  confirmedById          String?
  canceledById           String?
  canceledAt             DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  createdBy              User                 @relation("SmsCampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  confirmedBy            User?                @relation("SmsCampaignConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  canceledBy             User?                @relation("SmsCampaignCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)
  template               SmsTemplate?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients             SmsCampaignRecipient[]

  @@index([status])
  @@index([createdById])
  @@index([scheduledAt])
}

model SmsCampaignRecipient {
  id                    String             @id @default(uuid())
  campaignId            String
  recipientType         String
  recipientId           String
  recipientNameSnapshot String
  phoneSnapshot         String
  phoneNormalized       String
  renderedMessage       String
  providerName          String?
  providerMessageId     String?
  providerResponse      Json?
  status                SmsRecipientStatus @default(PENDING)
  attempts              Int                @default(0)
  errorMessage          String?
  sentAt                DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  campaign              SmsCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
}

model SmsTemplate {
  id           String        @id @default(uuid())
  name         String
  description  String?
  categoryHint String?
  content      String
  active       Boolean       @default(true)
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    User          @relation("SmsTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  campaigns    SmsCampaign[]

  @@index([active])
}

enum SmsCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENT
  PARTIALLY_SENT
  FAILED
  CANCELED
}

enum SmsRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  INVALID_PHONE
  CANCELED
}

enum SmsAudienceType {
  ALL_STUDENTS
  CLASS_GROUP
  STUDENTS_INCOMPLETE
  STUDENTS_COMPLETE
  STUDENTS_ACTIVE
  STUDENTS_INACTIVE
  BY_COURSE
  TEACHERS
  ADMINS
  ALL_ACTIVE_USERS
  ALL_CUSTOMERS
  CUSTOMERS_WITH_RESERVATIONS
}

// --- E-mail ---
model EmailCampaign {
  id                     String                @id @default(uuid())
  name                   String
  description            String?
  audienceType           EmailAudienceType
  audienceFilters        Json?
  templateId             String?
  subject                String?
  htmlContent            String?               @db.Text
  textContent            String?               @db.Text
  status                 EmailCampaignStatus   @default(DRAFT)
  totalFound             Int                   @default(0)
  totalValid             Int                   @default(0)
  totalMissingEmail      Int                   @default(0)
  totalInvalidEmail      Int                   @default(0)
  totalDuplicatesRemoved Int                   @default(0)
  totalSent              Int                   @default(0)
  totalDelivered         Int                   @default(0)
  totalFailed            Int                   @default(0)
  totalOpened            Int                   @default(0)
  totalClicked           Int                   @default(0)
  dispatchCount          Int                   @default(0)
  scheduledAt            DateTime?
  startedAt              DateTime?
  finishedAt             DateTime?
  createdById            String
  confirmedById          String?
  canceledById           String?
  canceledAt             DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  createdBy              User                  @relation("EmailCampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  confirmedBy            User?                 @relation("EmailCampaignConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  canceledBy             User?                 @relation("EmailCampaignCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)
  template               EmailTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients             EmailCampaignRecipient[]

  @@index([status])
  @@index([createdById])
  @@index([scheduledAt])
}

model EmailCampaignRecipient {
  id                    String               @id @default(uuid())
  campaignId            String
  recipientType         String
  recipientId           String
  recipientNameSnapshot String
  emailSnapshot         String
  emailNormalized       String
  renderedSubject       String
  renderedHtmlContent   String?              @db.Text
  renderedTextContent   String?              @db.Text
  providerName          String?
  providerMessageId     String?
  providerResponse      Json?
  status                EmailRecipientStatus @default(PENDING)
  attempts              Int                  @default(0)
  errorMessage          String?
  sentAt                DateTime?
  deliveredAt           DateTime?
  openedAt              DateTime?
  clickedAt             DateTime?
  bouncedAt             DateTime?
  complainedAt          DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  campaign              EmailCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
}

model EmailTemplate {
  id              String          @id @default(uuid())
  name            String
  description     String?
  categoryHint    String?
  subjectTemplate String
  htmlContent     String?         @db.Text
  textContent     String?         @db.Text
  active          Boolean         @default(true)
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       User            @relation("EmailTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  campaigns       EmailCampaign[]

  @@index([active])
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENT
  PARTIALLY_SENT
  FAILED
  CANCELED
}

enum EmailRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  INVALID_EMAIL
  BOUNCED
  COMPLAINED
  OPENED
  CLICKED
  CANCELED
}

enum EmailAudienceType {
  ALL_STUDENTS
  ENROLLED_STUDENTS
  CLASS_GROUP
  STUDENTS_INCOMPLETE
  STUDENTS_COMPLETE
  STUDENTS_ACTIVE
  STUDENTS_INACTIVE
  BY_COURSE
  SPECIFIC_STUDENTS
  TEACHERS
  ADMINS
  ALL_ACTIVE_USERS
  ALL_CUSTOMERS
  CUSTOMERS_WITH_RESERVATIONS
}
